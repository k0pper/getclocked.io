# getclocked.io — leaderboard / API environment.
# Copy to .env.local for local dev, and set the same vars in your Vercel project
# (Production + Preview + Development). The game is fully playable without any of
# these; they only enable accounts + the leaderboard.

# Neon Postgres — pooled connection string, used by the API at runtime.
DATABASE_URL=

# Neon direct (unpooled) connection — used by `pnpm db:migrate` for DDL.
# If unset, the migrate script falls back to DATABASE_URL.
DIRECT_URL=

# Signs single-use game tokens. Generate with:  openssl rand -base64 32
GAME_TOKEN_SECRET=

# Optional hardening: reject mutating requests whose Origin isn't exactly this.
# Production: https://getclocked.io   ·   Dev: http://localhost:5173
APP_ORIGIN=

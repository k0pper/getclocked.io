# Every dependency is pinned to an exact version (no ^ or ~) for reproducibility.
save-exact=true

# Enforce the Node/pnpm versions declared in package.json#engines.
engine-strict=true

# React 19 is new; some transitive deps still declare React 18 peer ranges.
# Warn instead of failing the install on unmet peers.
strict-peer-dependencies=false

# Non-interactive environment (agents/CI): let pnpm rebuild node_modules
# without a TTY confirmation prompt instead of aborting.
confirm-modules-purge=false

{
  "//": "Self-contained (NOT extends) because Vercel's function compiler reads this file but does not resolve `extends`, which would silently drop `strict` and `moduleResolution`. Keep in sync with ../tsconfig.base.json.",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,

    "strict": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "useDefineForClassFields": true,

    "types": ["node"],
    "noEmit": true
  },
  "include": ["."]
}
